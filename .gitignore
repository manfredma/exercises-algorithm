# ============================================================
# 同步自 java-gitignore 统一模板（2026-06-11）
# ============================================================

# [1] Maven 构建产物
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.flattened-pom.xml
**/.flattened-pom.xml
.mvn/timing.properties
test-output/
ut-rewrite-pom.xml
mdp_manifest

# [2] Java 运行时
hs_err_pid*
replay_pid*
rebel.xml

# [3] 日志 & 临时文件
logs/
log/
*.log
*.log.*
tmp/
*.tmp
*.bak
*.swp
*~
out/

# [4] IntelliJ IDEA
*.ipr
*.iws
*.idea_modules/

# [5] Eclipse
.classpath
.project
.settings/
.factorypath
.apt_generated
.springBeans
.sts4-cache
bin/

# [6] VS Code
.vscode/

# [7] Thrift / 代码生成产物
thrift/gen-java/
src/main/resources/META-INF/persistence.xml

# [8] macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
Icon

# [9] Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# [10] AI / 本地开发工具（不应提交到共享仓库）
.gstack/
.catpaw
.claude/
.history/

